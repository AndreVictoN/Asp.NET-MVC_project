@model FiapOnSmartCity.Models.ProductType

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Check Product Type";
}

<h1>Product Type - Check</h1>
<div class="form-horizontal col-sm-6">
    <hr />
    <div class="form-group">
        @Html.LabelFor(m => m.description, htmlAttributes: new { @class = "control-label col-md-2" })
        @Html.TextBoxFor(m => m.description, new { @readonly = "readonly" })
        @Html.ValidationMessageFor(m => m.description, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <label>Comercialized</label>
        <div class="checkbox">
            @Html.CheckBoxFor(m => m.isComercialized, new { @disabled = "disabled" })
        </div>
    </div>

    @Html.ActionLink("Back to List", "Index", "ProductType", null)
</div>